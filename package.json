{
  "name": "tirith",
  "version": "1.0.31",
  "description": "Terminal-based time tracker with vim keybindings",
  "homepage": "https://github.com/KamilMr/tirith#readme",
  "author": "kamil.mrowka@gmail.com",
  "type": "module",
  "license": "ISC",
  "bin": "dist/cli.js",
  "main": "index.js",
  "scripts": {
    "migrate": "npx knex migrate:latest --knexfile src/db/knexfile.js",
    "seed": "node src/db/seeds/testData.js",
    "build": "babel --out-dir=dist --watch src",
    "build:prod": "babel --out-dir=dist src",
    "start": "node --watch dist/index.js",
    "dev": "./scripts/start.sh",
    "format": "prettier --write .",
    "push": "npm version patch && ./scripts/push-docker.sh",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KamilMr/tirith.git"
  },
  "keywords": [
    "tirith",
    "nodejs",
    "toggle"
  ],
  "bugs": {
    "url": "https://github.com/KamilMr/tirith/issues"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@inquirer/prompts": "^5.5.0",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "fuse.js": "^7.1.0",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-table": "^3.1.0",
    "knex": "^3.1.0",
    "lodash": "^4.17.21",
    "mysql2": "^3.14.1",
    "react": "^18.3.1",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "prettier": "^3.6.2",
    "vitest": "^4.0.18"
  }
}
